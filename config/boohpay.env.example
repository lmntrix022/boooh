# Configuration BoohPay pour Bööh
# Copiez ces variables dans votre fichier .env

# URL de l'API BoohPay
# Développement: http://localhost:3000
# Production: https://api.boohpay.com
VITE_BOOHPAY_API_URL=http://localhost:3000

# Token admin BoohPay pour créer des merchants
# Obtenez ce token depuis la configuration BoohPay
VITE_BOOHPAY_ADMIN_TOKEN=your-admin-token-here

# Optionnel: API Key directe (pour tests uniquement)
# En production, utilisez la gestion automatique des merchants
# VITE_BOOHPAY_API_KEY=your-api-key-here








