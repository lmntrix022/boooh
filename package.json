{
  "name": "booh-card-magic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --config vite.config.analyze.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "lighthouse": "lhci autorun",
    "perf:analyze": "npm run build:analyze && npm run lighthouse",
    "perf:report": "npm run build && du -sh dist && find dist -name '*.js' -type f -exec du -h {} \\; | sort -rh | head -20",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:simple": "playwright test --config=playwright.config.simple.ts",
    "test:e2e:ui": "playwright test --config=playwright.config.simple.ts --ui",
    "test:e2e:headed": "playwright test --config=playwright.config.simple.ts --headed",
    "test:e2e:debug": "playwright test --config=playwright.config.simple.ts --debug",
    "test:all": "npm run test:unit && npm run test:e2e",
    "playwright:install": "playwright install --with-deps"
  },
